# ─── Required ───────────────────────────────────────────
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=change-me-to-a-random-string

# ─── External API (optional — defaults to jsoning.com) ───
# JSONING_API_URL=https://api.jsoning.com/mock/public

# ─── Database (optional — local SQLite used when unset) ─
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-auth-token

# ─── OAuth Providers (optional) ─────────────────────────
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=

# ─── Federation Remote URLs (optional — defaults to localhost) ─
# VITE_REMOTE_AUTH_URL=http://localhost:3001
# VITE_REMOTE_PRODUCT_URL=http://localhost:3002
# VITE_REMOTE_CART_URL=http://localhost:3003
# VITE_REMOTE_ORDER_URL=http://localhost:3004
# VITE_REMOTE_DASHBOARD_URL=http://localhost:3005

# ─── App Config (optional) ──────────────────────────────
# VITE_APP_TITLE=Micro-Frontend E-Commerce Platform
# VITE_API_URL=https://fakestoreapi.com
# SERVER_URL=http://localhost:3000
